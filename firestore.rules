rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Relaxed rules for development/demo mode to ensure admin/resta login and features work perfectly
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
    
    match /invoice_items/{itemId} {
      allow read, write: if true;
    }
    
    match /payment_methods/{methodId} {
      allow read, write: if true;
    }
  }
}